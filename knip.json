{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        ".githooks/pre-commit",
        ".github/workflows/*.yml",
        "package.json",
        "script/*.ts",
        "test/**/*.ts",
        "test/**/*.tsx"
      ],
      "project": ["script/**/*.ts", "test/**/*.ts", "test/**/*.tsx"]
    },
    "packages/*": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/brewva-cli": {
      "entry": ["src/**/*.ts", "runtime/**/*.ts", "runtime-assets/**/*.js"],
      "project": ["src/**/*.ts", "runtime/**/*.ts", "runtime-assets/**/*.js"]
    },
    "distribution/brewva": {
      "entry": ["bin/*.js"],
      "project": ["bin/*.js"]
    }
  },
  "ignoreWorkspaces": [
    "distribution/brewva-darwin-arm64",
    "distribution/brewva-linux-arm64",
    "distribution/brewva-linux-x64"
  ],
  "ignoreBinaries": ["codesign", "file", "python3", "tar", "taskkill"],
  "ignoreDependencies": ["@ff-labs/fff-bun", "@vscode/tree-sitter-wasm"],
  "ignoreUnresolved": [
    "../../config.js",
    "../../modes/interactive/theme/theme.js",
    "../session-manager.js",
    "../../../config.js"
  ]
}
