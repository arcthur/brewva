{
  "name": "brewva",
  "version": "0.1.0",
  "private": true,
  "description": "<p align=\"center\">   <a href=\"https://github.com/arcthur/brewva/actions/workflows/ci.yml?branch=main\"><img src=\"https://img.shields.io/github/actions/workflow/status/arcthur/brewva/ci.yml?branch=main&style=for-the-badge\" alt=\"CI status\"></a>   <a href=\"https://github.com/arcthur/brewva/releases\"><img src=\"https://img.shields.io/github/v/release/arcthur/brewva?include_prereleases&style=for-the-badge\" alt=\"GitHub release\"></a>   <a href=\"LICENSE\"><img src=\"https://img.shields.io/badge/License-Apache-blue.svg?style=for-the-badge\" alt=\"Apache License\"></a> </p>",
  "keywords": [],
  "license": "Apache-2.0",
  "author": "",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "workspaces": [
    "packages/*",
    "distribution/*"
  ],
  "type": "module",
  "main": "index.js",
  "scripts": {
    "analyze:projection": "bun run script/analyze-projection.ts",
    "build": "bun run typecheck && bun run build:binaries",
    "build:binaries": "bun run script/build-binaries.ts",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run typecheck:test && bun run test:import-boundaries && bun run check:security-patterns",
    "check:security-patterns": "bun run script/check-security-patterns.ts",
    "eval": "bun run test/eval/run-eval.ts --mode runtime",
    "eval:fixtures": "bun run test/eval/run-eval.ts --mode fixture",
    "eval:fixtures:summary": "bun run test/eval/run-eval.ts --mode fixture --runs 3",
    "eval:recall": "bun run test/eval/run-eval.ts --mode runtime --skill recall",
    "eval:recall:fixtures": "bun run test/eval/run-eval.ts --mode fixture --skill recall",
    "eval:recall:summary": "bun run test/eval/run-eval.ts --mode runtime --skill recall --runs 3",
    "eval:summary": "bun run test/eval/run-eval.ts --mode runtime --runs 3",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "format:docs": "git ls-files 'docs/**/*.md' 'docs/**/*.mdx' 'README.md' | xargs oxfmt --write",
    "format:docs:check": "git ls-files 'docs/**/*.md' 'docs/**/*.mdx' 'README.md' | xargs oxfmt --check",
    "generate:schema": "bun run script/generate-brewva-config-schema.ts",
    "install:local": "bash script/install-local.sh",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix && bun run format",
    "report:context-evidence": "bun run script/report-context-evidence.ts",
    "start": "bun run --preload @opentui/solid/preload packages/brewva-cli/src/index.ts",
    "test": "bun run test:default",
    "test:contract": "bun test test/contract --timeout 600000 --max-concurrency 8",
    "test:default": "bun run test:unit && bun run test:contract && bun run test:system && bun run test:quality",
    "test:dist": "bun run typecheck && bun run script/verify-dist.ts",
    "test:docs": "bun test test/quality/docs",
    "test:import-boundaries": "bun run script/check-test-import-boundaries.ts",
    "test:live": "BREWVA_TEST_LIVE=1 bun test test/live --timeout 600000",
    "test:live:boxlite": "BREWVA_TEST_LIVE=1 BREWVA_TEST_BOXLITE=1 bun test test/live/box/boxlite-stateful.live.test.ts --timeout 600000",
    "test:live:core": "BREWVA_TEST_LIVE=1 bun test test/live/cli test/live/channel test/live/provider/cost-tracking.live.test.ts test/live/provider/tool-call-proof.live.test.ts --timeout 600000",
    "test:live:interactive": "BREWVA_TEST_LIVE=1 bun test test/live/provider/interactive-multi-turn.live.test.ts --timeout 600000",
    "test:quality": "bun test test/quality --timeout 600000",
    "test:system": "bun test test/system --timeout 600000",
    "test:unit": "bun test test/unit --timeout 600000",
    "test:webhook-smoke": "bun run script/smoke-telegram-webhook-edge.ts",
    "test:webhook-smoke:live": "bun run script/smoke-telegram-webhook-live.ts",
    "typecheck": "tsc -b && bun run script/clean-package-dist.ts",
    "typecheck:test": "tsc -b test/tsconfig.json",
    "uninstall:local": "bash script/install-local.sh --uninstall"
  },
  "devDependencies": {
    "@brewva/brewva-agent-engine": "workspace:*",
    "@brewva/brewva-box": "workspace:*",
    "@brewva/brewva-channels-telegram": "workspace:*",
    "@brewva/brewva-cli": "workspace:*",
    "@brewva/brewva-deliberation": "workspace:*",
    "@brewva/brewva-gateway": "workspace:*",
    "@brewva/brewva-ingress": "workspace:*",
    "@brewva/brewva-provider-core": "workspace:*",
    "@brewva/brewva-recall": "workspace:*",
    "@brewva/brewva-runtime": "workspace:*",
    "@brewva/brewva-search": "workspace:*",
    "@brewva/brewva-session-index": "workspace:*",
    "@brewva/brewva-skill-broker": "workspace:*",
    "@brewva/brewva-substrate": "workspace:*",
    "@brewva/brewva-tools": "workspace:*",
    "@brewva/brewva-tui": "workspace:*",
    "@duckdb/node-api": "1.5.2-r.1",
    "@opentui/core": "0.1.100",
    "@opentui/solid": "0.1.100",
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "bun-types": "^1.3.12",
    "oxfmt": "0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "solid-js": "1.9.12",
    "ts-json-schema-generator": "^2.9.0",
    "typescript": "^6.0.2",
    "yaml": "^2.8.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "bun@1.3.12"
}
