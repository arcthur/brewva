{
  "name": "brewva",
  "version": "0.1.0",
  "private": true,
  "description": "<p align=\"center\">   <a href=\"https://github.com/arcthur/brewva/actions/workflows/ci.yml?branch=main\"><img src=\"https://img.shields.io/github/actions/workflow/status/arcthur/brewva/ci.yml?branch=main&style=for-the-badge\" alt=\"CI status\"></a>   <a href=\"https://github.com/arcthur/brewva/releases\"><img src=\"https://img.shields.io/github/v/release/arcthur/brewva?include_prereleases&style=for-the-badge\" alt=\"GitHub release\"></a>   <a href=\"LICENSE\"><img src=\"https://img.shields.io/badge/License-Apache-blue.svg?style=for-the-badge\" alt=\"Apache License\"></a> </p>",
  "keywords": [],
  "license": "Apache-2.0",
  "author": "",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "workspaces": [
    "packages/*",
    "distribution/*"
  ],
  "type": "module",
  "scripts": {
    "analyze:projection": "bun run script/analyze-projection.ts",
    "bench:tui": "bun run --preload @opentui/solid/preload test/bench/tui-streaming.bench.ts",
    "build": "bun run typecheck && bun run build:binaries",
    "build:binaries": "bun run script/build-binaries.ts",
    "check": "bun run format:check && bun run generate:schema:check && bun run docs:axiom-enforcement:check && bun run docs:inventory:check && bun run docs:runtime-subpaths:check && bun run docs:skill-navigation:check && bun run tools:capability-inventory:check && bun run lint && bun run lint:unused && bun run typecheck && bun run typecheck:test && bun run test:policy && bun run check:security-patterns",
    "check:security-patterns": "bun run script/check-security-patterns.ts",
    "docs:axiom-enforcement": "bun run script/generate-axiom-enforcement.ts --write",
    "docs:axiom-enforcement:check": "bun run script/generate-axiom-enforcement.ts --check",
    "docs:inventory": "bun run script/generate-doc-inventory.ts --write",
    "docs:inventory:check": "bun run script/generate-doc-inventory.ts --check",
    "docs:runtime-subpaths": "bun run script/generate-runtime-subpath-docs.ts --write",
    "docs:runtime-subpaths:check": "bun run script/generate-runtime-subpath-docs.ts --check",
    "docs:skill-navigation": "bun run script/generate-skill-navigation.ts --write",
    "docs:skill-navigation:check": "bun run script/generate-skill-navigation.ts --check",
    "eval": "bun run test/eval/run-eval.ts --mode runtime",
    "eval:fixtures": "bun run test/eval/run-eval.ts --mode fixture",
    "eval:fixtures:summary": "bun run test/eval/run-eval.ts --mode fixture --runs 3",
    "eval:recall": "bun run test/eval/run-eval.ts --mode runtime --skill recall",
    "eval:recall:fixtures": "bun run test/eval/run-eval.ts --mode fixture --skill recall",
    "eval:recall:summary": "bun run test/eval/run-eval.ts --mode runtime --skill recall --runs 3",
    "eval:summary": "bun run test/eval/run-eval.ts --mode runtime --runs 3",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "format:docs": "git ls-files 'docs/**/*.md' 'docs/**/*.mdx' 'README.md' | xargs oxfmt --write",
    "format:docs:check": "git ls-files 'docs/**/*.md' 'docs/**/*.mdx' 'README.md' | xargs oxfmt --check",
    "format:staged:check": "lint-staged --relative",
    "generate:schema": "bun run script/generate-brewva-config-schema.ts --write",
    "generate:schema:check": "bun run script/generate-brewva-config-schema.ts --check",
    "install:local": "bash script/install-local.sh",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix && bun run format",
    "lint:unused": "knip --dependencies --no-progress",
    "models:catalog": "bun run script/generate-provider-model-catalog.ts --write",
    "models:catalog:check": "bun run script/generate-provider-model-catalog.ts --check",
    "prepare": "./script/install-git-hooks.sh",
    "rdp:distill": "bun run script/rdp-distill.ts",
    "report:context-evidence": "bun run script/report-context-evidence.ts",
    "start": "bun run --preload @opentui/solid/preload packages/brewva-cli/src/index.ts",
    "test": "bun run test:ci",
    "test:ci": "bun run test:unit && bun run test:contract && bun run test:system && bun run test:fitness",
    "test:contract": "bun test test/contract --timeout 600000 --max-concurrency 8",
    "test:dist": "bun run typecheck && bun run script/verify-dist.ts",
    "test:docs": "bun run generate:schema:check && bun run docs:axiom-enforcement:check && bun run docs:inventory:check && bun run docs:runtime-subpaths:check && bun run docs:skill-navigation:check && bun test test/fitness/docs",
    "test:fitness": "bun test test/fitness --timeout 600000",
    "test:live": "BREWVA_TEST_LIVE=1 bun test test/live --timeout 600000",
    "test:live:boxlite": "BREWVA_TEST_LIVE=1 BREWVA_TEST_BOXLITE=1 bun test test/live/box/boxlite-stateful.live.test.ts --timeout 600000",
    "test:live:core": "BREWVA_TEST_LIVE=1 bun test test/live/cli test/live/channel test/live/provider/cost-tracking.live.test.ts test/live/provider/tool-call-proof.live.test.ts --timeout 600000",
    "test:live:interactive": "BREWVA_TEST_LIVE=1 bun test test/live/provider/interactive-multi-turn.live.test.ts --timeout 600000",
    "test:policy": "bun run script/check-test-policy.ts",
    "test:property": "BREWVA_PROPERTY_MODE=ci bun run script/run-property-tests.ts",
    "test:property:fuzz": "BREWVA_PROPERTY_MODE=fuzz bun run script/run-property-tests.ts",
    "test:system": "bun test test/system --timeout 600000",
    "test:tui": "CI= bun test test/unit/cli/opentui-shell-renderer-*.unit.test.ts --timeout 600000",
    "test:unit": "bun test test/unit --timeout 600000",
    "test:webhook-smoke": "bun run script/smoke-telegram-webhook-edge.ts",
    "test:webhook-smoke:live": "bun run script/smoke-telegram-webhook-live.ts",
    "tools:capability-inventory": "bun run script/generate-tool-runtime-capability-inventory.ts --write",
    "tools:capability-inventory:check": "bun run script/generate-tool-runtime-capability-inventory.ts --check",
    "typecheck": "tsc -b && bun run script/clean-package-dist.ts",
    "typecheck:test": "tsc -b test/tsconfig.json",
    "uninstall:local": "bash script/install-local.sh --uninstall"
  },
  "devDependencies": {
    "@brewva/brewva-channels-telegram": "workspace:*",
    "@brewva/brewva-cli": "workspace:*",
    "@brewva/brewva-effect": "workspace:*",
    "@brewva/brewva-gateway": "workspace:*",
    "@brewva/brewva-ingress-telegram": "workspace:*",
    "@brewva/brewva-mcp-adapter": "workspace:*",
    "@brewva/brewva-provider-core": "workspace:*",
    "@brewva/brewva-recall": "workspace:*",
    "@brewva/brewva-runtime": "workspace:*",
    "@brewva/brewva-search": "workspace:*",
    "@brewva/brewva-session-index": "workspace:*",
    "@brewva/brewva-std": "workspace:*",
    "@brewva/brewva-substrate": "workspace:*",
    "@brewva/brewva-token-estimation": "workspace:*",
    "@brewva/brewva-tools": "workspace:*",
    "@brewva/brewva-vocabulary": "workspace:*",
    "@opentui/core": "0.3.4",
    "@opentui/solid": "0.3.4",
    "@sinclair/typebox": "^0.34.49",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "bun-types": "^1.3.14",
    "fast-check": "4.8.0",
    "gpt-tokenizer": "3.4.0",
    "knip": "^6.15.0",
    "lint-staged": "^17.0.7",
    "oxfmt": "0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "solid-js": "1.9.13",
    "ts-json-schema-generator": "^2.9.0",
    "typescript": "^6.0.3",
    "ws": "^8.21.0",
    "yaml": "^2.9.0"
  },
  "lint-staged": {
    "*.{cjs,cts,js,jsx,json,jsonc,md,mdx,mjs,mts,ts,tsx}": "oxfmt --check"
  },
  "engines": {
    "node": "^20.19.0 || >=22.13.0"
  },
  "packageManager": "bun@1.3.12"
}
