{
  "name": "brewva",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*",
    "distribution/*"
  ],
  "type": "module",
  "scripts": {
    "analyze:projection": "bun run script/analyze-projection.ts",
    "build": "bun run typecheck && bun run build:binaries",
    "build:binaries": "bun run script/build-binaries.ts",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run typecheck:test && bun run test:import-boundaries",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "format:docs": "git ls-files 'docs/**/*.md' 'docs/**/*.mdx' 'README.md' | xargs oxfmt --write",
    "format:docs:check": "git ls-files 'docs/**/*.md' 'docs/**/*.mdx' 'README.md' | xargs oxfmt --check",
    "generate:schema": "bun run script/generate-brewva-config-schema.ts",
    "install:local": "bash script/install-local.sh",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix && bun run format",
    "start": "bun run packages/brewva-cli/src/index.ts",
    "test": "bun run test:default",
    "test:contract": "bun test test/contract --timeout 600000 --max-concurrency 8",
    "test:default": "bun run test:unit && bun run test:contract && bun run test:system && bun run test:quality",
    "test:dist": "bun run typecheck && bun run script/verify-dist.ts",
    "test:docs": "bun test test/quality/docs",
    "test:import-boundaries": "bun run script/check-test-import-boundaries.ts",
    "test:live": "BREWVA_TEST_LIVE=1 bun test test/live --timeout 600000",
    "test:live:core": "BREWVA_TEST_LIVE=1 bun test test/live/cli test/live/channel test/live/provider/cost-tracking.live.test.ts test/live/provider/microsandbox-isolation.live.test.ts test/live/provider/tool-call-proof.live.test.ts --timeout 600000",
    "test:live:interactive": "BREWVA_TEST_LIVE=1 bun test test/live/provider/interactive-multi-turn.live.test.ts --timeout 600000",
    "test:live:msb": "BREWVA_TEST_LIVE=1 BREWVA_TEST_MSB=1 bun test test/live/provider/microsandbox-isolation.live.test.ts --timeout 600000",
    "test:quality": "bun test test/quality --timeout 600000",
    "test:system": "bun test test/system --timeout 600000",
    "test:unit": "bun test test/unit --timeout 600000",
    "test:webhook-smoke": "bun run script/smoke-telegram-webhook-edge.ts",
    "test:webhook-smoke:live": "bun run script/smoke-telegram-webhook-live.ts",
    "typecheck": "tsc -b && bun run script/clean-package-dist.ts",
    "typecheck:test": "tsc -b test/tsconfig.json",
    "uninstall:local": "bash script/install-local.sh --uninstall"
  },
  "devDependencies": {
    "@brewva/brewva-channels-telegram": "workspace:*",
    "@brewva/brewva-cli": "workspace:*",
    "@brewva/brewva-deliberation": "workspace:*",
    "@brewva/brewva-gateway": "workspace:*",
    "@brewva/brewva-ingress": "workspace:*",
    "@brewva/brewva-runtime": "workspace:*",
    "@brewva/brewva-skill-broker": "workspace:*",
    "@brewva/brewva-tools": "workspace:*",
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "@types/node": "^25.2.3",
    "@types/ws": "^8.18.1",
    "bun-types": "^1.3.11",
    "oxfmt": "0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "ts-json-schema-generator": "^2.5.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "bun@1.3.11"
}
