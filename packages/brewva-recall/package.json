{
  "name": "@brewva/brewva-recall",
  "version": "0.1.0",
  "description": "Recall broker, curation state, and repository precedent search for Brewva.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./broker": {
      "types": "./dist/broker/index.d.ts",
      "bun": "./src/broker/index.ts",
      "import": "./dist/broker/index.js",
      "default": "./dist/broker/index.js"
    },
    "./knowledge": {
      "types": "./dist/knowledge/index.d.ts",
      "bun": "./src/knowledge/index.ts",
      "import": "./dist/knowledge/index.js",
      "default": "./dist/knowledge/index.js"
    },
    "./evidence": {
      "types": "./dist/evidence/index.d.ts",
      "bun": "./src/evidence/index.ts",
      "import": "./dist/evidence/index.js",
      "default": "./dist/evidence/index.js"
    }
  },
  "dependencies": {
    "@brewva/brewva-search": "workspace:*",
    "@brewva/brewva-session-index": "workspace:*",
    "@brewva/brewva-std": "workspace:*",
    "@brewva/brewva-vocabulary": "workspace:*",
    "fuse.js": "^7.3.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.13.0"
  }
}
