{
  "name": "@brewva/brewva-gateway",
  "version": "0.1.0",
  "description": "Hosted Brewva control plane, session supervision, and gateway composition.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./hosted": {
      "types": "./dist/hosted/api.d.ts",
      "bun": "./src/hosted/api.ts",
      "import": "./dist/hosted/api.js",
      "default": "./dist/hosted/api.js"
    },
    "./channels": {
      "types": "./dist/channels/api.d.ts",
      "bun": "./src/channels/api.ts",
      "import": "./dist/channels/api.js",
      "default": "./dist/channels/api.js"
    },
    "./daemon": {
      "types": "./dist/daemon/api.d.ts",
      "bun": "./src/daemon/api.ts",
      "import": "./dist/daemon/api.js",
      "default": "./dist/daemon/api.js"
    },
    "./admin": {
      "types": "./dist/admin/api.d.ts",
      "bun": "./src/admin/api.ts",
      "import": "./dist/admin/api.js",
      "default": "./dist/admin/api.js"
    },
    "./ingress": {
      "types": "./dist/ingress/api.d.ts",
      "bun": "./src/ingress/api.ts",
      "import": "./dist/ingress/api.js",
      "default": "./dist/ingress/api.js"
    },
    "./extensions": {
      "types": "./dist/extensions/api.d.ts",
      "bun": "./src/extensions/api.ts",
      "import": "./dist/extensions/api.js",
      "default": "./dist/extensions/api.js"
    },
    "./delegation": {
      "types": "./dist/delegation/api.d.ts",
      "bun": "./src/delegation/api.ts",
      "import": "./dist/delegation/api.js",
      "default": "./dist/delegation/api.js"
    },
    "./policy/model-routing": {
      "types": "./dist/policy/model-routing/api.d.ts",
      "bun": "./src/policy/model-routing/api.ts",
      "import": "./dist/policy/model-routing/api.js",
      "default": "./dist/policy/model-routing/api.js"
    },
    "./protocol": {
      "types": "./dist/protocol/api.d.ts",
      "bun": "./src/protocol/api.ts",
      "import": "./dist/protocol/api.js",
      "default": "./dist/protocol/api.js"
    }
  },
  "dependencies": {
    "@brewva/brewva-capabilities": "workspace:*",
    "@brewva/brewva-channels-telegram": "workspace:*",
    "@brewva/brewva-effect": "workspace:*",
    "@brewva/brewva-ingress-telegram": "workspace:*",
    "@brewva/brewva-mcp-adapter": "workspace:*",
    "@brewva/brewva-provider-core": "workspace:*",
    "@brewva/brewva-runtime": "workspace:*",
    "@brewva/brewva-search": "workspace:*",
    "@brewva/brewva-session-index": "workspace:*",
    "@brewva/brewva-std": "workspace:*",
    "@brewva/brewva-substrate": "workspace:*",
    "@brewva/brewva-token-estimation": "workspace:*",
    "@brewva/brewva-tools": "workspace:*",
    "@sinclair/typebox": "^0.34.49",
    "ajv": "^8.18.0",
    "lru-cache": "^11.3.5",
    "ws": "^8.20.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.13.0"
  }
}
