{
  "name": "@brewva/brewva-tools",
  "version": "0.1.0",
  "description": "Managed Brewva tool families, capability metadata, and default tool bundle.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "bun": "./src/contracts/index.ts",
      "import": "./dist/contracts/index.js",
      "default": "./dist/contracts/index.js"
    },
    "./registry": {
      "types": "./dist/registry/index.d.ts",
      "bun": "./src/registry/index.ts",
      "import": "./dist/registry/index.js",
      "default": "./dist/registry/index.js"
    },
    "./runtime-port": {
      "types": "./dist/runtime-port/index.d.ts",
      "bun": "./src/runtime-port/index.ts",
      "import": "./dist/runtime-port/index.js",
      "default": "./dist/runtime-port/index.js"
    },
    "./navigation": {
      "types": "./dist/families/navigation/api.d.ts",
      "bun": "./src/families/navigation/api.ts",
      "import": "./dist/families/navigation/api.js",
      "default": "./dist/families/navigation/api.js"
    },
    "./execution": {
      "types": "./dist/families/execution/api.d.ts",
      "bun": "./src/families/execution/api.ts",
      "import": "./dist/families/execution/api.js",
      "default": "./dist/families/execution/api.js"
    },
    "./memory": {
      "types": "./dist/families/memory/api.d.ts",
      "bun": "./src/families/memory/api.ts",
      "import": "./dist/families/memory/api.js",
      "default": "./dist/families/memory/api.js"
    },
    "./skills": {
      "types": "./dist/families/skills/api.d.ts",
      "bun": "./src/families/skills/api.ts",
      "import": "./dist/families/skills/api.js",
      "default": "./dist/families/skills/api.js"
    },
    "./delegation": {
      "types": "./dist/families/delegation/api.d.ts",
      "bun": "./src/families/delegation/api.ts",
      "import": "./dist/families/delegation/api.js",
      "default": "./dist/families/delegation/api.js"
    },
    "./workflow": {
      "types": "./dist/families/workflow/api.d.ts",
      "bun": "./src/families/workflow/api.ts",
      "import": "./dist/families/workflow/api.js",
      "default": "./dist/families/workflow/api.js"
    }
  },
  "dependencies": {
    "@brewva/brewva-effect": "workspace:*",
    "@brewva/brewva-recall": "workspace:*",
    "@brewva/brewva-runtime": "workspace:*",
    "@brewva/brewva-search": "workspace:*",
    "@brewva/brewva-std": "workspace:*",
    "@brewva/brewva-substrate": "workspace:*",
    "@brewva/brewva-token-estimation": "workspace:*",
    "@brewva/brewva-vocabulary": "workspace:*",
    "@sinclair/typebox": "^0.34.49",
    "@vscode/tree-sitter-wasm": "0.3.1",
    "date-fns": "^4.1.0",
    "eslint-scope": "^9.1.2",
    "fuse.js": "^7.3.0",
    "lru-cache": "^11.3.5",
    "magic-string": "^0.30.21",
    "oxc-parser": "0.128.0",
    "typescript": "^6.0.2",
    "web-tree-sitter": "0.25.10"
  },
  "engines": {
    "node": "^20.19.0 || >=22.13.0"
  }
}
