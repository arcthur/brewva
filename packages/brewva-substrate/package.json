{
  "name": "@brewva/brewva-substrate",
  "version": "0.1.0",
  "description": "Reusable Brewva session, prompt, resource, provider, tool, and agent protocol mechanisms.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./session": {
      "types": "./dist/session/index.d.ts",
      "bun": "./src/session/index.ts",
      "import": "./dist/session/index.js",
      "default": "./dist/session/index.js"
    },
    "./prompt": {
      "types": "./dist/prompt/index.d.ts",
      "bun": "./src/prompt/index.ts",
      "import": "./dist/prompt/index.js",
      "default": "./dist/prompt/index.js"
    },
    "./resources": {
      "types": "./dist/resources/index.d.ts",
      "bun": "./src/resources/index.ts",
      "import": "./dist/resources/index.js",
      "default": "./dist/resources/index.js"
    },
    "./provenance": {
      "types": "./dist/provenance/index.d.ts",
      "bun": "./src/provenance/index.ts",
      "import": "./dist/provenance/index.js",
      "default": "./dist/provenance/index.js"
    },
    "./execution": {
      "types": "./dist/execution/index.d.ts",
      "bun": "./src/execution/index.ts",
      "import": "./dist/execution/index.js",
      "default": "./dist/execution/index.js"
    },
    "./compaction": {
      "types": "./dist/compaction/index.d.ts",
      "bun": "./src/compaction/index.ts",
      "import": "./dist/compaction/index.js",
      "default": "./dist/compaction/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "bun": "./src/tools/index.ts",
      "import": "./dist/tools/index.js",
      "default": "./dist/tools/index.js"
    },
    "./host-api": {
      "types": "./dist/host-api/index.d.ts",
      "bun": "./src/host-api/index.ts",
      "import": "./dist/host-api/index.js",
      "default": "./dist/host-api/index.js"
    },
    "./persistence": {
      "types": "./dist/persistence/index.d.ts",
      "bun": "./src/persistence/index.ts",
      "import": "./dist/persistence/index.js",
      "default": "./dist/persistence/index.js"
    },
    "./provider": {
      "types": "./dist/provider/index.d.ts",
      "bun": "./src/provider/index.ts",
      "import": "./dist/provider/index.js",
      "default": "./dist/provider/index.js"
    },
    "./agent-protocol": {
      "types": "./dist/agent-protocol/index.d.ts",
      "bun": "./src/agent-protocol/index.ts",
      "import": "./dist/agent-protocol/index.js",
      "default": "./dist/agent-protocol/index.js"
    }
  },
  "dependencies": {
    "@brewva/brewva-effect": "workspace:*",
    "@brewva/brewva-provider-core": "workspace:*",
    "@brewva/brewva-std": "workspace:*",
    "@brewva/brewva-token-estimation": "workspace:*",
    "@sinclair/typebox": "^0.34.49",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "file-type": "^22.0.1",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.13.0"
  }
}
