{
  "name": "@brewva/brewva-cli",
  "version": "0.1.0",
  "description": "User-facing Brewva command surface and local interactive shell.",
  "license": "Apache-2.0",
  "bin": {
    "brewva": "./dist/index.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./internal-shell-runtime": {
      "types": "./dist/internal-shell-runtime.d.ts",
      "bun": "./runtime/internal-shell-runtime.ts",
      "import": "./dist/internal-shell-runtime.js",
      "default": "./dist/internal-shell-runtime.js"
    },
    "./entry": {
      "types": "./dist/entry/main.d.ts",
      "bun": "./src/entry/main.ts",
      "import": "./dist/entry/main.js",
      "default": "./dist/entry/main.js"
    },
    "./commands": {
      "types": "./dist/commands/index.d.ts",
      "bun": "./src/commands/index.ts",
      "import": "./dist/commands/index.js",
      "default": "./dist/commands/index.js"
    },
    "./channel": {
      "types": "./dist/commands/channel-handlers/index.d.ts",
      "bun": "./src/commands/channel-handlers/index.ts",
      "import": "./dist/commands/channel-handlers/index.js",
      "default": "./dist/commands/channel-handlers/index.js"
    },
    "./extensions": {
      "types": "./dist/commands/shell-extensions/index.d.ts",
      "bun": "./src/commands/shell-extensions/index.ts",
      "import": "./dist/commands/shell-extensions/index.js",
      "default": "./dist/commands/shell-extensions/index.js"
    },
    "./io/json-lines": {
      "types": "./dist/io/json-lines.d.ts",
      "bun": "./src/io/json-lines.ts",
      "import": "./dist/io/json-lines.js",
      "default": "./dist/io/json-lines.js"
    }
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@brewva/brewva-effect": "workspace:*",
    "@brewva/brewva-gateway": "workspace:*",
    "@brewva/brewva-runtime": "workspace:*",
    "@brewva/brewva-session-index": "workspace:*",
    "@brewva/brewva-std": "workspace:*",
    "@brewva/brewva-substrate": "workspace:*",
    "@brewva/brewva-token-estimation": "workspace:*",
    "@brewva/brewva-tools": "workspace:*",
    "@brewva/brewva-vocabulary": "workspace:*",
    "@opentui/core": "0.3.4",
    "@opentui/keymap": "0.3.4",
    "@opentui/solid": "0.3.4",
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "date-fns": "^4.3.0",
    "get-east-asian-width": "^1.6.0",
    "solid-js": "1.9.13"
  },
  "engines": {
    "node": "^20.19.0 || >=22.13.0"
  }
}
