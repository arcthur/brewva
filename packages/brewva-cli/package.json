{
  "name": "@brewva/brewva-cli",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "bin": {
    "brewva": "./dist/index.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./internal-shell-runtime": {
      "types": "./dist/internal-shell-runtime.d.ts",
      "bun": "./runtime/internal-shell-runtime.ts",
      "import": "./dist/internal-shell-runtime.js",
      "default": "./dist/internal-shell-runtime.js"
    },
    "./shell/state": {
      "types": "./dist/shell/state/index.d.ts",
      "bun": "./src/shell/state/index.ts",
      "import": "./dist/shell/state/index.js",
      "default": "./dist/shell/state/index.js"
    }
  },
  "dependencies": {
    "@brewva/brewva-gateway": "workspace:*",
    "@brewva/brewva-runtime": "workspace:*",
    "@brewva/brewva-session-index": "workspace:*",
    "@brewva/brewva-substrate": "workspace:*",
    "@brewva/brewva-tui": "workspace:*",
    "@opentui/core": "0.1.100",
    "@opentui/solid": "0.1.100",
    "chalk": "^5.6.2",
    "date-fns": "^4.1.0",
    "solid-js": "1.9.12"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
