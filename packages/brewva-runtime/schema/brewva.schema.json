{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/BrewvaConfigFile",
  "title": "brewva BrewvaConfigFile",
  "description": "JSON Schema for .brewva/brewva.json (Brewva config patch file).",
  "definitions": {
    "BrewvaConfigFile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "$schema": {
          "type": "string"
        },
        "channels": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "orchestration": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "aclModeWhenOwnersEmpty": {
                  "type": "string",
                  "enum": ["open", "closed"]
                },
                "enabled": {
                  "type": "boolean"
                },
                "limits": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "a2aMaxDepth": {
                      "type": "number"
                    },
                    "a2aMaxHops": {
                      "type": "number"
                    },
                    "fanoutMaxAgents": {
                      "type": "number"
                    },
                    "idleRuntimeTtlMs": {
                      "type": "number"
                    },
                    "maxDiscussionRounds": {
                      "type": "number"
                    },
                    "maxLiveRuntimes": {
                      "type": "number"
                    }
                  }
                },
                "owners": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "telegram": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "scopeStrategy": {
                  "type": "string",
                  "enum": ["chat", "thread"]
                }
              }
            }
          }
        },
        "infrastructure": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "contextBudget": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "arena": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "maxEntriesPerSession": {
                      "type": "number"
                    }
                  }
                },
                "compaction": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "minSecondsBetween": {
                      "type": "number"
                    },
                    "minTurnsBetween": {
                      "type": "number"
                    },
                    "pressureBypassPercent": {
                      "type": "number"
                    }
                  }
                },
                "compactionInstructions": {
                  "type": "string"
                },
                "enabled": {
                  "type": "boolean"
                },
                "injection": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "baseTokens": {
                      "type": "number"
                    },
                    "maxTokens": {
                      "type": "number"
                    },
                    "windowFraction": {
                      "type": "number"
                    }
                  }
                },
                "thresholds": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "compactionCeilingPercent": {
                      "type": "number"
                    },
                    "compactionFloorPercent": {
                      "type": "number"
                    },
                    "compactionHeadroomTokens": {
                      "type": "number"
                    },
                    "hardLimitCeilingPercent": {
                      "type": "number"
                    },
                    "hardLimitFloorPercent": {
                      "type": "number"
                    },
                    "hardLimitHeadroomTokens": {
                      "type": "number"
                    }
                  }
                }
              }
            },
            "costTracking": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "actionOnExceed": {
                  "type": "string",
                  "enum": ["warn", "block_tools"]
                },
                "alertThresholdRatio": {
                  "type": "number"
                },
                "enabled": {
                  "type": "boolean"
                },
                "maxCostUsdPerSession": {
                  "type": "number"
                }
              }
            },
            "events": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "dir": {
                  "type": "string"
                },
                "enabled": {
                  "type": "boolean"
                },
                "level": {
                  "type": "string",
                  "enum": ["audit", "ops", "debug"]
                }
              }
            },
            "interruptRecovery": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "gracefulTimeoutMs": {
                  "type": "number"
                }
              }
            },
            "toolFailureInjection": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "maxEntries": {
                  "type": "number"
                },
                "maxOutputChars": {
                  "type": "number"
                }
              }
            },
            "toolOutputDistillationInjection": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "maxEntries": {
                  "type": "number"
                },
                "maxOutputChars": {
                  "type": "number"
                }
              }
            },
            "turnWal": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "compactAfterMs": {
                  "type": "number"
                },
                "defaultTtlMs": {
                  "type": "number"
                },
                "dir": {
                  "type": "string"
                },
                "enabled": {
                  "type": "boolean"
                },
                "maxRetries": {
                  "type": "number"
                },
                "scheduleTurnTtlMs": {
                  "type": "number"
                }
              }
            }
          }
        },
        "ledger": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "checkpointEveryTurns": {
              "type": "number"
            },
            "path": {
              "type": "string"
            }
          }
        },
        "parallel": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "maxConcurrent": {
              "type": "number"
            },
            "maxTotalPerSession": {
              "type": "number"
            }
          }
        },
        "projection": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dir": {
              "type": "string"
            },
            "enabled": {
              "type": "boolean"
            },
            "maxWorkingChars": {
              "type": "number"
            },
            "workingFile": {
              "type": "string"
            }
          }
        },
        "schedule": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "leaseDurationMs": {
              "type": "number"
            },
            "maxActiveIntentsGlobal": {
              "type": "number"
            },
            "maxActiveIntentsPerSession": {
              "type": "number"
            },
            "maxConsecutiveErrors": {
              "type": "number"
            },
            "maxRecoveryCatchUps": {
              "type": "number"
            },
            "minIntervalMs": {
              "type": "number"
            },
            "staleOneShotRecoveryThresholdMs": {
              "type": "number"
            },
            "projectionPath": {
              "type": "string"
            }
          }
        },
        "security": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "boundaryPolicy": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "commandDenyList": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "filesystem": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "readAllow": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "writeAllow": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "writeDeny": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "network": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "allowLoopback": {
                      "type": "boolean"
                    },
                    "mode": {
                      "type": "string",
                      "enum": ["inherit", "deny", "allowlist"]
                    },
                    "outbound": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "properties": {
                          "host": {
                            "type": "string"
                          },
                          "ports": {
                            "type": "array",
                            "items": {
                              "type": "number"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "credentials": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "allowDerivedKeyFallback": {
                  "type": "boolean"
                },
                "bindings": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "credentialRef": {
                        "type": "string"
                      },
                      "envVar": {
                        "type": "string"
                      },
                      "toolNames": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "gatewayTokenRef": {
                  "type": "string"
                },
                "masterKeyEnv": {
                  "type": "string"
                },
                "path": {
                  "type": "string"
                },
                "sandboxApiKeyRef": {
                  "type": "string"
                }
              }
            },
            "enforcement": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "effectAuthorizationMode": {
                  "$ref": "#/definitions/SecurityEnforcementPreference"
                },
                "skillMaxParallelMode": {
                  "$ref": "#/definitions/SecurityEnforcementPreference"
                },
                "skillMaxTokensMode": {
                  "$ref": "#/definitions/SecurityEnforcementPreference"
                },
                "skillMaxToolCallsMode": {
                  "$ref": "#/definitions/SecurityEnforcementPreference"
                }
              },
              "required": [
                "effectAuthorizationMode",
                "skillMaxTokensMode",
                "skillMaxToolCallsMode",
                "skillMaxParallelMode"
              ]
            },
            "execution": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "backend": {
                  "type": "string",
                  "enum": ["host", "sandbox", "best_available"]
                },
                "enforceIsolation": {
                  "type": "boolean"
                },
                "fallbackToHost": {
                  "type": "boolean"
                },
                "sandbox": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "cpus": {
                      "type": "number"
                    },
                    "defaultImage": {
                      "type": "string"
                    },
                    "memory": {
                      "type": "number"
                    },
                    "serverUrl": {
                      "type": "string"
                    },
                    "timeout": {
                      "type": "number"
                    }
                  }
                }
              }
            },
            "loopDetection": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "exactCall": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "type": "boolean"
                    },
                    "exemptTools": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "mode": {
                      "type": "string",
                      "enum": ["warn", "block"]
                    },
                    "threshold": {
                      "type": "number"
                    }
                  }
                }
              }
            },
            "mode": {
              "type": "string",
              "enum": ["permissive", "standard", "strict"]
            },
            "sanitizeContext": {
              "type": "boolean"
            }
          }
        },
        "skills": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "disabled": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "overrides": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/definitions/SkillContractOverride"
              }
            },
            "roots": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "routing": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "scopes": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/SkillRoutingScope"
                  }
                }
              }
            }
          }
        },
        "tape": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "checkpointIntervalEntries": {
              "type": "number"
            }
          }
        },
        "ui": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "quietStartup": {
              "type": "boolean"
            }
          }
        },
        "verification": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "checks": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "quick": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "standard": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "strict": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "commands": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "defaultLevel": {
              "$ref": "#/definitions/VerificationLevel"
            }
          }
        }
      }
    },
    "SecurityEnforcementMode": {
      "type": "string",
      "enum": ["off", "warn", "enforce"]
    },
    "SecurityEnforcementPreference": {
      "anyOf": [
        {
          "$ref": "#/definitions/SecurityEnforcementMode"
        },
        {
          "type": "string",
          "const": "inherit"
        }
      ]
    },
    "SkillCompletionDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requiredEvidenceKinds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verificationLevel": {
          "$ref": "#/definitions/VerificationLevel"
        }
      }
    },
    "SkillContractOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "composableWith": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "consumes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "effects": {
          "$ref": "#/definitions/SkillEffectsOverride"
        },
        "executionHints": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "costHint": {
              "$ref": "#/definitions/SkillCostHint"
            },
            "fallbackTools": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "preferredTools": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "suggestedChains": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/SkillSuggestedChain"
              }
            }
          }
        },
        "intent": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "completionDefinition": {
              "$ref": "#/definitions/SkillCompletionDefinition"
            },
            "outputContracts": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/definitions/SkillOutputContract"
              }
            },
            "outputs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "requires": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resources": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "defaultLease": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "maxParallel": {
                  "type": "number"
                },
                "maxTokens": {
                  "type": "number"
                },
                "maxToolCalls": {
                  "type": "number"
                }
              }
            },
            "hardCeiling": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "maxParallel": {
                  "type": "number"
                },
                "maxTokens": {
                  "type": "number"
                },
                "maxToolCalls": {
                  "type": "number"
                }
              }
            }
          }
        },
        "routing": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "scope": {
              "$ref": "#/definitions/SkillRoutingScope"
            }
          }
        },
        "stability": {
          "type": "string",
          "enum": ["experimental", "stable", "deprecated"]
        }
      }
    },
    "SkillCostHint": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "SkillEffectsOverride": {
      "$ref": "#/definitions/SkillEffectsPolicy"
    },
    "SkillEffectsPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowedEffects": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ToolEffectClass"
          }
        },
        "deniedEffects": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ToolEffectClass"
          }
        }
      }
    },
    "SkillOutputContract": {
      "anyOf": [
        {
          "$ref": "#/definitions/SkillOutputTextContract"
        },
        {
          "$ref": "#/definitions/SkillOutputEnumContract"
        },
        {
          "$ref": "#/definitions/SkillOutputJsonContract"
        }
      ]
    },
    "SkillOutputEnumContract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "caseSensitive": {
          "type": "boolean"
        },
        "kind": {
          "type": "string",
          "const": "enum"
        },
        "values": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["kind", "values"]
    },
    "SkillOutputJsonContract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "const": "json"
        },
        "minItems": {
          "type": "number"
        },
        "minKeys": {
          "type": "number"
        }
      },
      "required": ["kind"]
    },
    "SkillOutputTextContract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "const": "text"
        },
        "minLength": {
          "type": "number"
        },
        "minWords": {
          "type": "number"
        }
      },
      "required": ["kind"]
    },
    "SkillRoutingScope": {
      "type": "string",
      "enum": ["core", "domain", "operator", "meta"]
    },
    "SkillSuggestedChain": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "steps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["steps"]
    },
    "ToolEffectClass": {
      "type": "string",
      "enum": [
        "workspace_read",
        "workspace_write",
        "local_exec",
        "runtime_observe",
        "external_network",
        "external_side_effect",
        "schedule_mutation",
        "memory_write"
      ]
    },
    "VerificationLevel": {
      "type": "string",
      "enum": ["quick", "standard", "strict"]
    }
  }
}
