                "servers": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/BrewvaMcpServerConfig"
                  }
                }
              }
            }
          }
        },
        "ledger": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "checkpointEveryTurns": {
              "type": "number"
            },
            "path": {
              "type": "string"
            }
          }
        },
        "parallel": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "maxConcurrent": {
              "type": "number"
            },
            "maxTotalPerSession": {
              "type": "number"
            }
          }
        },
        "planning": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mapEnabled": {
              "description": "Opt-in switch for the durable planning-map managed tools (default off).",
              "type": "boolean"
            }
          }
        },
        "projection": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dir": {
              "type": "string"
            },
            "enabled": {
              "type": "boolean"
            },
            "maxWorkingChars": {
              "type": "number"
            },
            "workingFile": {
              "type": "string"
            }
          }
        },
        "schedule": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "leaseDurationMs": {
              "type": "number"
            },
            "maxActiveIntentsGlobal": {
              "type": "number"
            },
            "maxActiveIntentsPerSession": {
              "type": "number"
            },
            "maxConsecutiveErrors": {
              "type": "number"
            },
            "maxRecoveryCatchUps": {
              "type": "number"
            },
            "minIntervalMs": {
              "type": "number"
            },
            "projectionPath": {
              "type": "string"
            },
            "selfImprove": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "continuityMode": {
                  "type": "string",
                  "enum": ["inherit", "fresh"]
                },
                "cron": {
                  "type": "string"
                },
                "enabled": {
                  "type": "boolean"
                },
                "goalRef": {
                  "type": "string"
                },
                "intentId": {
                  "$ref": "#/definitions/BrewvaIntentId"
                },
                "maxRuns": {
                  "type": "number"
                },
                "parentSessionId": {
                  "$ref": "#/definitions/BrewvaSessionId"
                },
                "reason": {
                  "type": "string"
                },
                "taskSpec": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "constraints": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "expectedBehavior": {
                      "type": "string"
                    },
                    "goal": {
                      "type": "string"
                    }
                  }
                },
                "timeZone": {
                  "type": "string"
                }
              }
            },
            "staleOneShotRecoveryThresholdMs": {
              "type": "number"
            }
          }
        },
        "security": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "actionAdmissionOverrides": {
              "$ref": "#/definitions/ToolActionAdmissionOverrides"
            },
            "boundaryPolicy": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "commandDenyList": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "filesystem": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "readAllow": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "writeAllow": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "writeDeny": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "network": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "allowLoopback": {
                      "type": "boolean"
                    },
                    "mode": {
                      "type": "string",
                      "enum": ["inherit", "deny", "allowlist"]
                    },
                    "outbound": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "properties": {
                          "host": {
                            "type": "string"
                          },
                          "ports": {
                            "type": "array",
                            "items": {
                              "type": "number"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "credentials": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "allowDerivedKeyFallback": {
                  "type": "boolean"
                },
                "bindings": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "credentialRef": {
                        "type": "string"
                      },
                      "envVar": {
                        "type": "string"
                      },
                      "toolNames": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    }
                  }
                },
                "boxSecretsRef": {
                  "type": "string"
                },
                "gatewayTokenRef": {
                  "type": "string"
                },
                "masterKeyEnv": {
                  "type": "string"
                },
                "path": {
                  "type": "string"
                }
              }
            },
            "enforcement": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "effectAuthorizationMode": {
                  "$ref": "#/definitions/SecurityEnforcementPreference"
                },
                "skillMaxParallelMode": {
                  "$ref": "#/definitions/SecurityEnforcementPreference"
                },
                "skillMaxTokensMode": {
                  "$ref": "#/definitions/SecurityEnforcementPreference"
                },
                "skillMaxToolCallsMode": {
                  "$ref": "#/definitions/SecurityEnforcementPreference"
                }
              },
              "required": [
                "effectAuthorizationMode",
                "skillMaxTokensMode",
                "skillMaxToolCallsMode",
                "skillMaxParallelMode"
              ]
            },
            "execution": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "autoBackground": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "foregroundWaitMs": {
                      "type": "number"
                    },
                    "verificationForegroundWaitMs": {
                      "description": "Foreground wait for verification-class commands (builds, tests, linters), which are usually worth blocking on so a typical run completes in one exec call instead of a background + poll loop. Explicit per-call yieldMs still wins.",
                      "type": "number"
                    }
                  },
                  "required": ["foregroundWaitMs", "verificationForegroundWaitMs"]
                },
                "backend": {
                  "type": "string",
                  "enum": ["host", "box"]
                },
                "box": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "autoSnapshotOnRelease": {
                      "type": "boolean"
                    },
                    "cpus": {
                      "type": "number"
                    },
                    "detach": {
                      "type": "boolean"
                    },
                    "diskGb": {
                      "type": "number"
                    },
                    "gc": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "maxAgeDays": {
                          "type": "number"
                        },
                        "maxStoppedBoxes": {
                          "type": "number"
                        }
                      }
                    },
                    "home": {
                      "type": "string"
                    },
                    "image": {
                      "type": "string"
                    },
                    "memoryMib": {
                      "type": "number"
                    },
                    "network": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "allow": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "mode": {
                          "type": "string",
                          "enum": ["off", "allowlist"]
                        }
                      }
                    },
                    "perSessionLifetime": {
                      "type": "string",
                      "enum": ["session", "forever"]
                    },
                    "scopeDefault": {
                      "type": "string",
                      "enum": ["session", "task", "ephemeral"]
                    },
                    "workspaceGuestPath": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "loopDetection": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "exactCall": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": {
                      "type": "boolean"
                    },
                    "exemptTools": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "mode": {
                      "type": "string",
                      "enum": ["warn", "block"]
                    },
                    "threshold": {
                      "type": "number"
                    }
                  }
                }
              }
            },
            "mode": {
              "type": "string",
              "enum": ["permissive", "standard", "strict"]
            },
            "sanitizeContext": {
              "type": "boolean"
            }
          }
        },
        "skills": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "disabled": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "roots": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "tape": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "checkpointIntervalEntries": {
              "type": "number"
            },
            "dir": {
              "type": "string"
            },
            "enabled": {
              "type": "boolean"
            }
          }
        },
        "ui": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "quietStartup": {
              "type": "boolean"
            }
          }
        },
        "verification": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "checks": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "quick": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "standard": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "strict": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "commands": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "defaultLevel": {
              "$ref": "#/definitions/VerificationLevel"
            }
          }
        },
        "worlds": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dir": {
              "type": "string"
            },
            "enabled": {
              "type": "boolean"
            },
            "retainPerSession": {
              "type": "number"
            }
          }
        }
      }
    },
    "BrewvaIdentifier<\"BrewvaIntentId\">": {
      "type": "string"
    },
    "BrewvaIdentifier<\"BrewvaSessionId\">": {
      "type": "string"
    },
    "BrewvaIntentId": {
      "$ref": "#/definitions/BrewvaIdentifier%3C%22BrewvaIntentId%22%3E"
    },
    "BrewvaMcpServerConfig": {
      "anyOf": [
        {
          "$ref": "#/definitions/BrewvaMcpStdioServerConfig"
        },
        {
          "$ref": "#/definitions/BrewvaMcpStreamableHttpServerConfig"
        }
      ]
    },
    "BrewvaMcpStdioServerConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "command": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "envAllowlist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "id": {
          "type": "string"
        },
        "includeToolNames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inheritEnv": {
          "type": "boolean",
          "const": false
        },
        "timeoutMs": {
          "type": "number"
        },
        "toolPolicies": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/BrewvaMcpToolPolicyConfig"
          }
        },
        "transport": {
          "type": "string",
          "const": "stdio"
        }
      },
      "required": [
        "args",
        "command",
        "enabled",
        "env",
        "envAllowlist",
        "id",
        "includeToolNames",
        "inheritEnv",
        "timeoutMs",
        "toolPolicies",
        "transport"
      ]
    },
    "BrewvaMcpStreamableHttpServerConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "id": {
          "type": "string"
        },
        "includeToolNames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "timeoutMs": {
          "type": "number"
        },
        "toolPolicies": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/BrewvaMcpToolPolicyConfig"
          }
        },
        "transport": {
          "type": "string",
          "const": "streamable_http"
        },
        "url": {
          "type": "string"
        }
      },
      "required": [
        "enabled",
        "headers",
        "id",
        "includeToolNames",
        "timeoutMs",
        "toolPolicies",
        "transport",
        "url"
      ]
    },
    "BrewvaMcpToolPolicyConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "actionClass": {
          "$ref": "#/definitions/ToolActionClass"
        },
        "surface": {
          "$ref": "#/definitions/BrewvaMcpToolSurfaceOverride"
        }
      }
    },
    "BrewvaMcpToolSurfaceOverride": {
      "type": "string",
      "enum": ["base", "skill", "control_plane", "operator"]
    },
    "BrewvaSessionId": {
      "$ref": "#/definitions/BrewvaIdentifier%3C%22BrewvaSessionId%22%3E"
    },
    "SecurityEnforcementMode": {
      "type": "string",
      "enum": ["off", "warn", "enforce"]
    },
    "SecurityEnforcementPreference": {
      "anyOf": [
        {
          "$ref": "#/definitions/SecurityEnforcementMode"
        },
        {
          "type": "string",
          "const": "inherit"
        }
      ]
    },
    "ToolActionAdmissionOverrides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "budget_mutation": {
          "$ref": "#/definitions/ToolAdmissionBehavior"
        },
        "control_state_mutation": {
          "$ref": "#/definitions/ToolAdmissionBehavior"
        },
        "credential_access": {
          "$ref": "#/definitions/ToolAdmissionBehavior"
        },
        "delegation": {
          "$ref": "#/definitions/ToolAdmissionBehavior"
        },
        "external_side_effect": {
          "$ref": "#/definitions/ToolAdmissionBehavior"
        },
        "local_exec_effectful": {
          "$ref": "#/definitions/ToolAdmissionBehavior"
        },
        "local_exec_readonly": {
          "$ref": "#/definitions/ToolAdmissionBehavior"
        },
        "memory_write": {
          "$ref": "#/definitions/ToolAdmissionBehavior"
        },
        "runtime_observe": {
          "$ref": "#/definitions/ToolAdmissionBehavior"
        },
        "schedule_mutation": {
          "$ref": "#/definitions/ToolAdmissionBehavior"
        },
        "workspace_patch": {
          "$ref": "#/definitions/ToolAdmissionBehavior"
        },
        "workspace_read": {
          "$ref": "#/definitions/ToolAdmissionBehavior"
        }
      }
    },
    "ToolActionClass": {
      "type": "string",
      "enum": [
        "workspace_read",
        "runtime_observe",
        "workspace_patch",
        "memory_write",
        "control_state_mutation",
        "budget_mutation",
        "local_exec_readonly",
        "local_exec_effectful",
        "external_side_effect",
        "schedule_mutation",
        "delegation",
        "credential_access"
      ]
    },
    "ToolAdmissionBehavior": {
      "type": "string",
      "enum": ["allow", "ask", "deny"]
    },
    "VerificationLevel": {
      "type": "string",
      "enum": ["quick", "standard", "strict"]
    }
  }
}
