{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/BrewvaConfigFile",
  "title": "brewva BrewvaConfigFile",
  "description": "JSON Schema for .brewva/brewva.json (Brewva config patch file).",
  "definitions": {
