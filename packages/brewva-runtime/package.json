{
  "name": "@brewva/brewva-runtime",
  "version": "0.1.0",
  "description": "Replay-first Brewva runtime authority, governance, events, and public contracts.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "bun": "./src/core.ts",
      "import": "./dist/core.js",
      "default": "./dist/core.js"
    },
    "./schema/brewva.schema.json": "./schema/brewva.schema.json",
    "./config": {
      "types": "./dist/config.d.ts",
      "bun": "./src/config.ts",
      "import": "./dist/config.js",
      "default": "./dist/config.js"
    },
    "./security": {
      "types": "./dist/security.d.ts",
      "bun": "./src/security.ts",
      "import": "./dist/security.js",
      "default": "./dist/security.js"
    }
  },
  "dependencies": {
    "@brewva/brewva-std": "workspace:*",
    "@brewva/brewva-token-estimation": "workspace:*",
    "ajv": "^8.20.0",
    "date-fns": "^4.3.0",
    "jsonc-parser": "^3.3.1",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.13.0"
  }
}
